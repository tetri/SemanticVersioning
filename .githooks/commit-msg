#!/bin/sh
#
# Validate conventional commit message format.
# Regex: type(optional-scope): description
# Types: feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert
# Also allows merge/revert commit messages.
#
COMMIT_MSG=$(cat "$1")

# Skip merge and revert commits (auto-generated by git)
echo "$COMMIT_MSG" | grep -qE '^Merge .*|^Revert .*' && exit 0

# Validate conventional commit format
if ! echo "$COMMIT_MSG" | grep -qE '^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-zA-Z0-9._-]+\))?!?: .+'; then
    echo ""
    echo "  ERROR: Invalid commit message format!"
    echo ""
    echo "  Expected: type(optional-scope): description"
    echo ""
    echo "  Valid types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert"
    echo ""
    echo "  Examples:"
    echo "    feat: add new feature"
    echo "    fix(auth): fix login validation"
    echo "    docs: update API documentation"
    echo "    feat!: breaking change with ! indicator"
    echo "    chore(deps): bump xunit to 3.1.0"
    echo ""
    echo "  See: https://www.conventionalcommits.org/"
    echo ""
    exit 1
fi

exit 0
